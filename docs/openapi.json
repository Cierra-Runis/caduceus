{
  "openapi": "3.1.0",
  "info": {
    "title": "caduceus API",
    "description": "REST API of the caduceus collaborative Typst editor. Protected routes authenticate via a JWT, sent either as an HttpOnly `token` cookie or an `Authorization: Bearer` header.",
    "license": {
      "name": ""
    },
    "version": "0.1.0"
  },
