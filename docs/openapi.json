    "/api/project/{id}/duplicate": {
      "post": {
        "tags": [
          "project"
        ],
        "summary": "Clone a project the caller can access into a new, independent project.\nAccess is enforced inside `ProjectService::duplicate` itself (mirroring\n`update_file`), so there is no separate check here.",
        "operationId": "duplicate",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Source project id (24-char hex ObjectId)",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The newly created copy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiSuccess_ProjectPayload"
                }
