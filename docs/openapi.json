  "components": {
    "schemas": {
      "ApiMessage": {
        "type": "object",
        "description": "Doc-only mirror of [`crate::models::response::ApiResponse`] for bodies\nwithout a payload: every error response, plus payload-less successes such\nas logout. `#[serde(skip_serializing_if)]` removes the `payload` key\nentirely in this case, so the wire shape is just `{ \"message\": ... }`.",
        "required": [
          "message"
        ],
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "ApiSuccess_AuthPayload": {
        "type": "object",
        "description": "Doc-only mirror of [`crate::models::response::ApiResponse`] for responses\nthat always carry a payload. `ApiResponse.payload` is an `Option` only so\none struct can serve both cases; on the wire a success body is always\n`{ \"message\": ..., \"payload\": ... }`, which is what this schema states\n(a `ToSchema` derive on the real struct would wrongly mark `payload`\noptional and nullable). A test below pins this equivalence.",
        "required": [
          "message",
          "payload"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "payload": {
            "type": "object",
            "required": [
              "user",
              "token"
            ],
            "properties": {
              "token": {
                "type": "string"
              },
              "user": {
                "$ref": "#/components/schemas/UserPayload"
              }
            }
          }
        }
      },
      "ApiSuccess_HealthPayload": {
        "type": "object",
        "description": "Doc-only mirror of [`crate::models::response::ApiResponse`] for responses\nthat always carry a payload. `ApiResponse.payload` is an `Option` only so\none struct can serve both cases; on the wire a success body is always\n`{ \"message\": ..., \"payload\": ... }`, which is what this schema states\n(a `ToSchema` derive on the real struct would wrongly mark `payload`\noptional and nullable). A test below pins this equivalence.",
        "required": [
          "message",
          "payload"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "payload": {
            "type": "object",
            "required": [
              "status"
            ],
            "properties": {
              "status": {
                "$ref": "#/components/schemas/HealthStatus"
              }
            }
          }
        }
      },
      "ApiSuccess_ProjectDetailPayload": {
        "type": "object",
        "description": "Doc-only mirror of [`crate::models::response::ApiResponse`] for responses\nthat always carry a payload. `ApiResponse.payload` is an `Option` only so\none struct can serve both cases; on the wire a success body is always\n`{ \"message\": ..., \"payload\": ... }`, which is what this schema states\n(a `ToSchema` derive on the real struct would wrongly mark `payload`\noptional and nullable). A test below pins this equivalence.",
        "required": [
          "message",
          "payload"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "payload": {
            "type": "object",
            "description": "Editor-facing payload for opening a single project. Unlike [`ProjectPayload`]\n(used by the list endpoints), this inlines text file content: the Typst\ncompiler resolves `#import`/`#image` across the *entire* file tree, not just\nthe focused tab, so the client needs the whole virtual FS up front. Lazy\nper-file loading would not serve the preview.",
            "required": [
              "id",
              "name",
              "owner_id",
              "owner_type",
              "creator_id",
              "files",
              "created_at",
              "updated_at",
              "entry",
              "pinned_version"
            ],
            "properties": {
              "created_at": {
                "type": "string",
                "format": "date-time"
              },
              "creator_id": {
                "type": "string"
              },
              "entry": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "The compile entry, as the file's id (hex). The client resolves it to a\npath against `files` — id is the stable key, path can be renamed."
              },
              "files": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ProjectFileDetailPayload"
                }
              },
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "owner_id": {
                "type": "string"
              },
              "owner_type": {
                "$ref": "#/components/schemas/OwnerType"
              },
              "pinned_version": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "updated_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      },
      "ApiSuccess_ProjectPayload": {
        "type": "object",
        "description": "Doc-only mirror of [`crate::models::response::ApiResponse`] for responses\nthat always carry a payload. `ApiResponse.payload` is an `Option` only so\none struct can serve both cases; on the wire a success body is always\n`{ \"message\": ..., \"payload\": ... }`, which is what this schema states\n(a `ToSchema` derive on the real struct would wrongly mark `payload`\noptional and nullable). A test below pins this equivalence.",
        "required": [
          "message",
          "payload"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "payload": {
            "type": "object",
            "required": [
              "id",
              "name",
              "owner_id",
              "owner_type",
              "creator_id",
              "files",
              "created_at",
              "updated_at",
              "entry",
              "pinned_version"
            ],
            "properties": {
              "created_at": {
                "type": "string",
                "format": "date-time"
              },
              "creator_id": {
                "type": "string"
              },
              "entry": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "files": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ProjectFilePayload"
                }
              },
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "owner_id": {
                "type": "string"
              },
              "owner_type": {
                "$ref": "#/components/schemas/OwnerType"
              },
              "pinned_version": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "updated_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      },
      "ApiSuccess_TeamPayload": {
        "type": "object",
        "description": "Doc-only mirror of [`crate::models::response::ApiResponse`] for responses\nthat always carry a payload. `ApiResponse.payload` is an `Option` only so\none struct can serve both cases; on the wire a success body is always\n`{ \"message\": ..., \"payload\": ... }`, which is what this schema states\n(a `ToSchema` derive on the real struct would wrongly mark `payload`\noptional and nullable). A test below pins this equivalence.",
        "required": [
          "message",
          "payload"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "payload": {
            "type": "object",
            "required": [
              "id",
              "name",
              "avatar_uri",
              "creator_id",
              "member_ids",
              "created_at",
              "updated_at"
            ],
            "properties": {
              "avatar_uri": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "created_at": {
                "type": "string",
                "format": "date-time"
              },
              "creator_id": {
                "type": "string"
              },
              "id": {
                "type": "string"
              },
              "member_ids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "name": {
